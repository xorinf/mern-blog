# ------------------------------------
# BACKEND/SERVER ENVIRONMENT VARIABLES
# ------------------------------------

# Database connection (e.g., MongoDB Atlas URI)
DB_ADDRESS=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/mern_blog

# API Server Port (usually 6767 in local, but Vercel manages this automatically)
PORT=6767

# Make sure this matches your deployed frontend URL exactly (e.g. https://my-frontend.vercel.app)
FRONTEND_URL=http://localhost:5173

# Secret random string for JWT Signing
JWT_SECRET=YOUR_SUPER_SECRET_JWT_KEY_HERE_12345

# Salt rounds for Bcrypt hashing
SALT=12

# Cloudinary Integration (for Image Uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key_1234
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_abcd

# Set this to "production" ONLY when deploying to Vercel/live environments!
NODE_ENV=development

# ------------------------------------
# FRONTEND/VITE ENVIRONMENT VARIABLES
# ------------------------------------
# (If running Frontend separately, you'd place this inside frontend/.env)

# Points to your API. Leave blank locally so it proxies via vite.config.js, 
# or set to https://my-backend-deployment.vercel.app in production.
VITE_BACKEND_URL=
